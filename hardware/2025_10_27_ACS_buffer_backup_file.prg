!PNAME=
!PDESC=
DISP "BUFFER 3 Gantry Z Homing"
INT ZECOffset_ControlWord
INT ZECOffset_TouchProbeFunction
INT ZECOffset_ActualPosition
INT Slave_Number 			= 1
ZECOffset_ControlWord 		= ECGETOFFSET ("Controlword" , Slave_Number)
ZECOffset_ActualPosition 	= ECGETOFFSET ("Position Actual Value" , Slave_Number)
DISABLE AX_Z
MFLAGS(AX_Z).#HOME = 0

FMASK(AX_Z).#RL	= 1
FMASK(AX_Z).#LL	= 1
FDEF(AX_Z).#RL	= 0
FDEF(AX_Z).#LL	= 0

DISP "Z SOFT LIMITS DISABLE"
FMASK(AX_Z).#SRL 	= 0
FMASK(AX_Z).#SLL 	= 0
SRLIMIT(AX_Z)		= 32
SLLIMIT(AX_Z)		= -2					
ACC (AX_Z)		= 2000
DEC (AX_Z)		= 2000
KDEC(AX_Z)		= 3000
JERK (AX_Z)		= 10000

!Control Word Unmap
ECUNMAPIN(ZECOffset_ControlWord)
ECUNMAPOUT(ZECOffset_ControlWord)

DISP "Z Fault Clear Loop"
LOOP 2
	ECOUT(ZECOffset_ControlWord,ControlWord_Z)
	ControlWord_Z = 0x8F
	WAIT 150
	ControlWord_Z = 0x0F
	WAIT 150
	ECUNMAPIN(ZECOffset_ControlWord)
	ECUNMAPOUT(ZECOffset_ControlWord)
	WAIT 100
END
DISP "Z JOGGING TO RIGHT LIMIT"
ENABLE AX_Z
JOG/v AX_Z, 10
TILL FAULT(AX_Z).#RL = 1
HALT AX_Z
WAIT 100

DISP "Z Initiating touch probe"
INT Touch_Probe_Status = 0
REAL Index_Position
WHILE ^(Touch_Probe_Status = 1)
	COEWRITE/2 (Slave_Number,0x60B8,0,0x0)
	WAIT 100
	COEWRITE/2 (Slave_Number,0x60B8,0,0x15)
	WAIT 100
	Touch_Probe_Status = COEREAD/2(Slave_Number, 0x60B9, 0)
END
!**********************************************************
PTP/rv AX_Z,-20,10
DISP "Z Looking for index"
JOG/v AX_Z,-1
WAIT 200
WHILE ^(Touch_Probe_Status=67)
	Touch_Probe_Status=COEREAD/2 (Slave_Number,0x60B9,0)
	IF (Touch_Probe_Status = 67 )
		KILL AX_Z
		WAIT 300
	END
END
!!************************************************
ECIN (ZECOffset_ActualPosition, ActualPos_Z)
SET FPOS(AX_Z)=ActualPos_Z/1000
Index_Position=(COEREAD/4 (Slave_Number,0x60BA,0))/1000
SET FPOS(AX_Z)=(FPOS(AX_Z)-Index_Position)
WAIT 100

FMASK(AX_Z).#RL 	= 1
FMASK(AX_Z).#LL 	= 1
FDEF(AX_Z).#RL 		= 1
FDEF(AX_Z).#LL 		= 1
FDEF(AX_Z).#PE		= 0
FMASK(AX_Z).#PE		= 0
ERRA(AX_Z)			= 2
ERRI(AX_Z)			= 2
PTP/rv AX_Z,-10,10
TILL ^MST(AX_Z).#MOVE
WAIT 250
SET FPOS(AX_Z) = 0

VEL (AX_Z) 	= 50
ACC (AX_Z) 	= 1500
DEC (AX_Z) 	= 1500
KDEC(AX_Z) 	= 10000
JERK (AX_Z) = 50000

FMASK(AX_Z).#SRL 	= 1
FMASK(AX_Z).#SLL 	= 1
FDEF(AX_Z).#SRL 		= 1
FDEF(AX_Z).#SLL 		= 1						 
MFLAGS(AX_Z).#HOME = 1
DISP "Z HOMED"
DISP "BUFFER 3 STOPPED"
STOP 
