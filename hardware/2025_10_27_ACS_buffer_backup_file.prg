!PNAME=
!PDESC=
!Gantry X Homing
ERRORUNMAP 0,0
DISABLE AX_X_COG, AX_X_YAW
S_SETUP.#SINCOSRP=1
MFLAGS(AX_X_COG).#HOME = 0
MFLAGS(AX_X_YAW).#HOME = 0
CALL DISABLE_SAFETY_MASKS
CALL INPUTSHAPING_OFF
CALL NONGANTRY_PARAMTERS
CALL X_IND_HOMING
WAIT 500

REAL MIDEAN, YAW
MIDEAN 	= (FPOS(AX_X_COG)+FPOS(AX_X_YAW))/2
YAW 	= (FPOS(AX_X_YAW)-FPOS(AX_X_COG));
SET FPOS(AX_X_COG) = MIDEAN
SET FPOS(AX_X_YAW) = YAW
CALL GANTRY_PARAMETERS
SET FPOS(AX_X_COG) = 0
SET FPOS(AX_X_YAW) = FPOS(AX_X_YAW)-YAW
CALL GANTRY_SETTINGS 
CALL INPUTSHAPING_ON
CALL RESTORE_SAFETY_PARA
MFLAGS(AX_X_COG).#HOME 	= 1
MFLAGS(AX_X_YAW).#HOME	= 1
TILL FVEL(AX_X_COG)<0.05
TILL ^PST(3).#RUN,20000
ENABLE AX_X_COG
STOP

!################## SUB ROUNTINES ##################
DISABLE_SAFETY_MASKS:
	DISP "DISABLE X SAFETY MASKS"
	FMASK(AX_X_COG).#SRL = 0;	FMASK(AX_X_YAW).#SRL = 0;
	FMASK(AX_X_COG).#SLL = 0;	FMASK(AX_X_YAW).#SLL = 0;
RET

RESTORE_SAFETY_PARA:
	DISP "RESTORE X SAFETY PARAMETERS"
	SRLIMIT(AX_X_COG)		= 395 ;	SRLIMIT(AX_X_YAW)		= 5 ;
	SLLIMIT(AX_X_COG)		= -25 ;	SLLIMIT(AX_X_YAW)		= -5 ;
	
	FMASK(AX_X_COG).#SRL 	= 1 ;	FMASK(AX_X_YAW).#SRL 	= 1 ;
	FMASK(AX_X_COG).#SLL 	= 1 ;	FMASK(AX_X_YAW).#SLL 	= 1 ;
	FMASK(AX_X_COG).#RL		= 1 ;	FMASK(AX_X_YAW).#RL		= 1 ;
	FMASK(AX_X_COG).#LL		= 1 ;	FMASK(AX_X_YAW).#LL		= 1 ;
	FMASK(AX_X_COG).#HOT	= 1 ;	FMASK(AX_X_YAW).#HOT	= 1 ;
	FMASK(AX_X_COG).#ENCNC	= 0 ;	FMASK(AX_X_YAW).#ENCNC	= 0 ;
	FMASK(AX_X_COG).#ENC2NC	= 0 ;	FMASK(AX_X_YAW).#ENC2NC	= 0 ;
	FMASK(AX_X_COG).#DRIVE	= 1 ;	FMASK(AX_X_YAW).#DRIVE	= 1 ;
	FMASK(AX_X_COG).#PE		= 0 ;	FMASK(AX_X_YAW).#PE		= 0 ;
	FMASK(AX_X_COG).#VL		= 1 ;	FMASK(AX_X_YAW).#VL		= 1 ;
	FMASK(AX_X_COG).#STO	= 1 ;	FMASK(AX_X_YAW).#STO	= 1 ;
RET

INPUTSHAPING_OFF:
	DISP "X INPUTSHAPING OFF"
	InShapeOFF AX_X_COG
RET

INPUTSHAPING_ON:
	DISP "X INPUTSHAPING ON"
	REAL InShapeTime(3);
	REAL InShapeSamples(3);
	InShapeTime(0)			= CTIME*00; 	InShapeSamples(0)		= 53909/1e5;
	InShapeTime(1)			= CTIME*45; 	InShapeSamples(1)		= 25179/1e5;
	InShapeTime(2)			= CTIME*46; 	InShapeSamples(2)		= 20912/1e5;
	InShapeOn AX_X_COG, InShapeTime, InShapeSamples
	WAIT 100
RET



GANTRY_SETTINGS:
	DISP "APPLY X GANTRY SETTINGS"
	FMASK(AX_X_COG).#RL		= 1 ;	FMASK(AX_X_YAW).#RL		= 0 ;
	FMASK(AX_X_COG).#LL		= 1 ;	FMASK(AX_X_YAW).#LL		= 0 ;
	FDEF(AX_X_COG).#RL 		= 1
	FDEF(AX_X_COG).#LL 		= 1
	FDEF(AX_X_COG).#SRL 	= 1
	FDEF(AX_X_COG).#SLL 	= 1
	
	VEL(AX_X_COG) 		= 1000
	ACC(AX_X_COG) 		= 6000
	DEC(AX_X_COG) 		= 6000
	JERK(AX_X_COG) 		= 180000
	KDEC(AX_X_COG)		= 12000
RET

NONGANTRY_PARAMTERS:
	DISP "APPLY X NON GANTRY PARAMETERS"
	FMASK(AX_X_COG).#RL = 1;	FMASK(AX_X_YAW).#RL = 1;
	FMASK(AX_X_COG).#LL = 1;	FMASK(AX_X_YAW).#LL = 1;
	FDEF(AX_X_COG).#RL 	= 0;	FDEF(AX_X_YAW).#RL 	= 0;
	FDEF(AX_X_COG).#LL 	= 0;	FDEF(AX_X_YAW).#LL 	= 0;
	
	DISP "SERVOBOOST DISABLED"
	SLSBORD(AX_X_COG) 	= 0;	SLSBORD(AX_X_YAW) 	= 0;

	ACC (AX_X_COG) 		= 1000;	ACC (AX_X_YAW) 		= 1000;
	DEC (AX_X_COG) 		= 1000;	DEC (AX_X_YAW) 		= 1000;
	KDEC(AX_X_COG) 		= 1000;	KDEC(AX_X_YAW) 		= 1000;
	JERK (AX_X_COG) 	= 5000;	JERK (AX_X_YAW) 	= 5000;
		
!X1 X2
	MFLAGS(AX_X_COG).#GANTRY 	= 0 ;	MFLAGS(AX_X_YAW).#GANTRY	= 0 ;
	SLPKP(AX_X_COG) 			= 50 ;	SLPKP(AX_X_YAW) 			= 50 ;
	SLVKP(AX_X_COG) 			= 300 ;	SLVKP(AX_X_YAW) 			= 300 ;
	SLVKI(AX_X_COG) 			= 50 ;	SLVKI(AX_X_YAW) 			= 50 ;
	SLVSOF(AX_X_COG) 			= 200 ;	SLVSOF(AX_X_YAW)			= 200 ;
	SLVSOFD(AX_X_COG) 			= 0.8 ;	SLVSOFD(AX_X_YAW) 			= 0.8 ;
	SLVKPIF(AX_X_COG)			= 1.2
	SLJFF(AX_X_COG)				= 0.25
	
	MFLAGS(AX_X_COG).#NOTCH 	= 0	;	MFLAGS(AX_X_YAW).#NOTCH 	= 0 ;
	MFLAGS(AX_X_COG).#BI_QUAD	= 0 ;	MFLAGS(AX_X_YAW).#BI_QUAD	= 0 ;
	MFLAGS(AX_X_COG).#BI_QUAD1	= 0 ;	MFLAGS(AX_X_YAW).#BI_QUAD1	= 0 ;

	XCURV(AX_X_COG) 			= 25 ;	XCURV(AX_X_YAW) 			= 25 ;
	XCURI(AX_X_COG) 			= 10 ;	XCURI(AX_X_YAW) 			= 15 ;
	SLAFF(AX_X_COG)				= 100;	SLAFF(AX_X_YAW) 			= 100;

	Gantry_Mode = 0
WAIT 100
RET

GANTRY_PARAMETERS:
	DISP "APPLY X GANTRY PARAMETERS"
	DISABLE (AX_X_COG, AX_X_YAW)
	MFLAGS(AX_X_COG).#GANTRY 	= 1;	MFLAGS(AX_X_YAW).#GANTRY	= 1;
	
	DISP "APPLY X COG SERVOBOOST"
	! ServoBoost
	SLSBORD(AX_X_COG)= 1;	SLSBORD(AX_X_YAW)= 0;		!ServoBoost Enable
	SLSBBW(AX_X_COG) = 70;	SLSBBW(AX_X_YAW) = 30;
	SLSBF(AX_X_COG)	 = 700;	SLSBF(AX_X_YAW)  = 200;
	
	! Current Saturation	
	XCURV(AX_X_COG)	= 100;	XCURV(AX_X_YAW) = 30;
	XCURI(AX_X_COG)	= 70;	XCURI(AX_X_YAW) = 15;
			 
	! Loops Gains
	SLIKP(AX_X_COG) = 1000;	SLIKP(AX_X_YAW) = 1000;		!Current Loop proportional
	SLIKI(AX_X_COG) = 200; SLIKI(AX_X_COG) = 200;		!Current Loop Integral
	SLPKP(AX_X_COG)	= 65;	SLPKP(AX_X_YAW) = 70;		!Position Loop proportional
	SLVKP(AX_X_COG)	= 350;	SLVKP(AX_X_YAW) = 250;		!Velocity Loop Proportional
	SLVKI(AX_X_COG)	= 250;	SLVKI(AX_X_YAW) = 200;		!Velocity loop Integral
		
	! Velocity Low Pass Filter
	MFLAGS(AX_X_COG).#NOFILT= 0;MFLAGS(AX_X_YAW).#NOFILT= 0;	
	SLVSOF(AX_X_COG)= 220;		SLVSOF(AX_X_YAW)= 50;	! Filter Bandwidth
	SLVSOFD(AX_X_COG)= 0.5;		SLVSOFD(AX_X_YAW)= 0.8;	! Filter Damping
		
	! Velocity Notch Filter 
	MFLAGS(AX_X_COG).#NOTCH=1;	MFLAGS(AX_X_YAW).#NOTCH= 1;
	SLVNATT(AX_X_COG)= 2;		SLVNATT(AX_X_YAW)= 3;  	! Notch Attenuation
	SLVNFRQ(AX_X_COG)= 200;		SLVNFRQ(AX_X_YAW)= 110; ! Notch Frequency
	SLVNWID(AX_X_COG)= 4;		SLVNWID(AX_X_YAW)= 15;  ! Notch Width
		
	! Velocity BiQuad Filter
	MFLAGS(AX_X_COG).#BI_QUAD= 0;  MFLAGS(AX_X_YAW).#BI_QUAD= 0; 
	SLVB0DD(AX_X_COG)= 0.1;		SLVB0DD(AX_X_YAW)= 0.8;  ! Denominator Damping
	SLVB0DF(AX_X_COG)= 950;		SLVB0DF(AX_X_YAW)= 180;  ! Denominator Frequency
	SLVB0ND(AX_X_COG)= 0.05;	SLVB0ND(AX_X_YAW)= 0.3;  ! Numerator Damping						
	SLVB0NF(AX_X_COG)= 950;		SLVB0NF(AX_X_YAW)= 300;  ! Numerator Frequency
		
	! Velocity BiQuad Filter 1 
	MFLAGS(AX_X_COG).#BI_QUAD1= 0;  MFLAGS(AX_X_YAW).#BI_QUAD1= 0;
	SLVB1DD(AX_X_COG)= 0.4;		SLVB1DD(AX_X_YAW)= 0.4; ! Denominator Damping						
	SLVB1DF(AX_X_COG)= 60;		SLVB1DF(AX_X_YAW)= 60; 	! Denominator Frequency
	SLVB1ND(AX_X_COG)= 0.6;		SLVB1ND(AX_X_YAW)= 0.6; ! Numerator Damping						
	SLVB1NF(AX_X_COG)= 60;		SLVB1NF(AX_X_YAW)= 60; 	! Numerator Frequency
		
	! FeedForward
	SLAFF(AX_X_COG)= 240;		SLAFF(AX_X_YAW)= 100;
	
	DISP "OPEN YAW"				
	MFLAGS(AX_X_YAW).#OPEN	= 1				
	Gantry_Mode = 1
RET

X_IND_HOMING:
	DISP "X0 X2 HOMING"
	MFLAGS(AX_X_COG).#OPEN = 0
	MFLAGS(AX_X_YAW).#OPEN = 0
	
	ENABLE (AX_X_COG, AX_X_YAW)
	JOG/v (AX_X_COG, AX_X_YAW), -50
	TILL (FAULT(AX_X_COG).#LL) & (FAULT(AX_X_YAW).#LL)
	HALT (AX_X_COG, AX_X_YAW)		
	IST(AX_X_COG).#IND=0 
	IST(AX_X_YAW).#IND=0 
	JOG/v (AX_X_COG,AX_X_YAW),20
	WAIT 100
	DISP "JOGGING TO INDEX"
	TILL IST(AX_X_COG).#IND & IST(AX_X_YAW).#IND 		
	HALT (AX_X_COG, AX_X_YAW)
	TILL ^AST(AX_X_COG).#MOVE & ^AST(AX_X_YAW).#MOVE
	WAIT 100
	SET FPOS(AX_X_COG)=FPOS(AX_X_COG)-IND(AX_X_COG)
	SET FPOS(AX_X_YAW)=FPOS(AX_X_YAW)-IND(AX_X_YAW)
	ENABLE (AX_X_COG, AX_X_YAW)
	DISP "X COG AND YAW ENABLED"
RET
