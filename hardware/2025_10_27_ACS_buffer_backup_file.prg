	ECUNMAPIN(ECGETOFFSET/b("Input",DELTA_IN_UNIT1_SLAVE_ID,1,4))
	ECUNMAPIN(ECGETOFFSET/b("Input",DELTA_IN_UNIT1_SLAVE_ID,1,5))
