	ECUNMAPIN(ECGETOFFSET/b("Input",DELTA_IN_UNIT1_SLAVE_ID,1,8))
	ECUNMAPIN(ECGETOFFSET/b("Input",DELTA_IN_UNIT1_SLAVE_ID,1,9))
	ECUNMAPIN(ECGETOFFSET/b("Input",DELTA_IN_UNIT1_SLAVE_ID,1,10))
	ECUNMAPIN(ECGETOFFSET/b("Input",DELTA_IN_UNIT1_SLAVE_ID,1,11))
	ECUNMAPIN(ECGETOFFSET/b("Input",DELTA_IN_UNIT1_SLAVE_ID,1,12))
	ECUNMAPIN(ECGETOFFSET/b("Input",DELTA_IN_UNIT1_SLAVE_ID,1,13))
	ECUNMAPIN(ECGETOFFSET/b("Input",DELTA_IN_UNIT1_SLAVE_ID,1,14))
	ECUNMAPIN(ECGETOFFSET/b("Input",DELTA_IN_UNIT1_SLAVE_ID,1,15))
	
	DISP "OUTPUT UNIT 1 UNPAMMING"
	ECUNMAPOUT(ECGETOFFSET/b("Output",DELTA_OUT_UNIT1_SLAVE_ID,0,0))
	ECUNMAPOUT(ECGETOFFSET/b("Output",DELTA_OUT_UNIT1_SLAVE_ID,0,1))
	ECUNMAPOUT(ECGETOFFSET/b("Output",DELTA_OUT_UNIT1_SLAVE_ID,0,2))
	ECUNMAPOUT(ECGETOFFSET/b("Output",DELTA_OUT_UNIT1_SLAVE_ID,0,3))
	ECUNMAPOUT(ECGETOFFSET/b("Output",DELTA_OUT_UNIT1_SLAVE_ID,0,4))
	ECUNMAPOUT(ECGETOFFSET/b("Output",DELTA_OUT_UNIT1_SLAVE_ID,0,5))
	ECUNMAPOUT(ECGETOFFSET/b("Output",DELTA_OUT_UNIT1_SLAVE_ID,0,6))
	ECUNMAPOUT(ECGETOFFSET/b("Output",DELTA_OUT_UNIT1_SLAVE_ID,0,7))
	ECUNMAPOUT(ECGETOFFSET/b("Output",DELTA_OUT_UNIT1_SLAVE_ID,0,8))
	ECUNMAPOUT(ECGETOFFSET/b("Output",DELTA_OUT_UNIT1_SLAVE_ID,0,9))
	ECUNMAPOUT(ECGETOFFSET/b("Output",DELTA_OUT_UNIT1_SLAVE_ID,0,10))
	ECUNMAPOUT(ECGETOFFSET/b("Output",DELTA_OUT_UNIT1_SLAVE_ID,0,11))
	ECUNMAPOUT(ECGETOFFSET/b("Output",DELTA_OUT_UNIT1_SLAVE_ID,0,12))
	ECUNMAPOUT(ECGETOFFSET/b("Output",DELTA_OUT_UNIT1_SLAVE_ID,0,13))
	ECUNMAPOUT(ECGETOFFSET/b("Output",DELTA_OUT_UNIT1_SLAVE_ID,0,14))
	ECUNMAPOUT(ECGETOFFSET/b("Output",DELTA_OUT_UNIT1_SLAVE_ID,0,15))
	
	DISP "DIGITAL INPUT UNIT 1 MAPPING"
	ECIN/b(ECGETOFFSET/b("Input",DELTA_IN_UNIT1_SLAVE_ID,1,1),Reset_Button_Bit)										!IN 0.0
	ECIN/b(ECGETOFFSET/b("Input",DELTA_IN_UNIT1_SLAVE_ID,1,2),Start_Button_Bit)										!IN 0.1
	ECIN/b(ECGETOFFSET/b("Input",DELTA_IN_UNIT1_SLAVE_ID,1,3),Stop_Button_Bit)						!IN 0.2
		
	!Outputs
	DISP "DIGITAL OUTPUT UNIT 1 MAPPING"
	ECOUT/b(ECGETOFFSET/b("Output",DELTA_OUT_UNIT1_SLAVE_ID,0,1),ResetButtonLight_Bit)							!OUT 0.0
	ECOUT/b(ECGETOFFSET/b("Output",DELTA_OUT_UNIT1_SLAVE_ID,0,2),StartButtonLight_Bit)							!OUT 0.1
	ECOUT/b(ECGETOFFSET/b("Output",DELTA_OUT_UNIT1_SLAVE_ID,0,3),StopButtonLight_Bit)							!OUT 0.2
	
IF START_UP = 0
	ResetButtonLight_Bit = 1
ELSE
	ResetButtonLight_Bit = 0
END
	
!AX_Z Left(-) limit sensor response initialization
IF Z_Digital_Input.17
	SAFINI(AX_Z).#LL=1
ELSE
	SAFINI(AX_Z).#LL=0
END

!AX_Z right(+) limit sensor response initialization
IF Z_Digital_Input.16
	SAFINI(AX_Z).#RL=1
ELSE
	SAFINI(AX_Z).#RL=0
END

STOP

! Z left limit
ON Z_Digital_Input.17 = 0
	SAFINI(AX_Z).#LL=0
RET
ON Z_Digital_Input.17 = 1
	SAFINI(AX_Z).#LL= 1
RET

! Z right limit
ON Z_Digital_Input.16 = 0
	SAFINI(AX_Z).#RL=0
RET
ON Z_Digital_Input.16 = 1
	SAFINI(AX_Z).#RL= 1
RET

Z_RESET:
	DISP "Z RESET"
	Z_ECOffset_ControlWord = ECGETOFFSET ("Controlword" , Z_Slave_Number)
	LOOP 2
		!*********Unmapping ethercat offset for control word******
		ECUNMAPIN(Z_ECOffset_ControlWord)
		ECUNMAPOUT(Z_ECOffset_ControlWord)
		!***************************************
		WAIT 300		
		DISP "Z Fault Clear"
		ECOUT(Z_ECOffset_ControlWord,ControlWord_Z)
		ControlWord_Z = 0x8F
		WAIT 300
		ControlWord_Z = 0x0F
		WAIT 300
	END
		
	ECUNMAPIN(Z_ECOffset_ControlWord)
	ECUNMAPOUT(Z_ECOffset_ControlWord)
	WAIT 300
RET

ON Reset_Button_Bit
	START 0,1
	TILL ^MST(AX_X_COG).#MOVE
	START 1,1
	TILL ^MST(AX_Y).#MOVE
	START 3,1
	TILL ^MST(AX_Z).#MOVE
	ResetButtonLight_Bit = 0
	WAIT 5000
	START_UP = 1
	M_Ready = 1
	StartButtonLight_Bit = 1
RET

ON Start_Button_Bit
	IF M_Ready
		StartButtonLight_Bit = 0
		StopButtonLight_Bit  = 1
		ResetButtonLight_Bit = 0
		START 5,1
		M_Busy 	= 1
		M_Ready = 0
		DISP "Start"
	ELSE
		DISP "Need To Reset"
	END
RET

ON Stop_Button_Bit
	IF M_Busy
		STOP 5
		KILL 0,1
		DISP "Stop All"
		M_Ready = 1
		M_Busy 	= 0
		StartButtonLight_Bit = 1
		StopButtonLight_Bit = 0
	END
RET
