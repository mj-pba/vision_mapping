!PNAME=
!PDESC=
DISP "BUFFER 1 Gantry Y homing"
INT SEARCH_VEL
INT HOME_VEL
SEARCH_VEL			=20
HOME_VEL			=50
DISABLE AX_Y
ERRORUNMAP 1,0

MFLAGS(AX_Y).#HOME 	= 0	
CALL SOFT_LIMIT
CALL RESTORE_TUNING_PARA
CALL INPUTSHAPING_OFF
CALL LOAD_HOMING_PARA
CALL LIMIT_CURRENT
CALL HOME_Y !**************
CALL RESTORE_TUNING_PARA						
CALL RESTORE_SAFETY_MASKS
CALL RESTORE_MOTION_PARA
CALL INPUTSHAPING_ON
MFLAGS(AX_Y).#HOME = 1

DISP "BUFFER 1 STOPPED"
STOP

!###################### SUB ROUTINES ################
HOME_Y:
	DISP "Y HOMING"
	ENABLE AX_Y
	JOG/v AX_Y, -HOME_VEL
	TILL FAULT(AX_Y).#LL= 1
	KILL AX_Y
	TILL ^AST(AX_Y).#MOVE
	WAIT 100
	IST(AX_Y).#IND=0 
	JOG/v AX_Y,SEARCH_VEL
	DISP "JOGGING TO Y INDEX"
	WAIT 100
	TILL IST(AX_Y).#IND 
	KILL AX_Y
	TILL ^AST(AX_Y).#MOVE
	WAIT 100
	SET FPOS(AX_Y)=FPOS(AX_Y)-IND(AX_Y)
	CALL RESTORE_CURRENT
	PTP/ve AX_Y,0,100
RET

SOFT_LIMIT:
	DISP "Y SOFT LIITS APPLIED"
	FMASK(AX_Y).#SRL 	= 0
	FMASK(AX_Y).#SLL 	= 0
	SRLIMIT(AX_Y)		= 305
	SLLIMIT(AX_Y)		=-16
 
RET
LIMIT_CURRENT:
	XCURV(AX_Y) 		= 15
	XCURI(AX_Y) 		= 5
RET
RESTORE_CURRENT:
	XCURV(AX_Y) 		= 100
	XCURI(AX_Y) 		= 50
RET
LOAD_HOMING_PARA:
	DISP "Y HOMING PARAMETERS LOADED"
	FMASK(AX_Y).#RL 	= 1
	FMASK(AX_Y).#LL 	= 1
	FDEF(AX_Y).#RL 		= 0
	FDEF(AX_Y).#LL 		= 0
	SLSBORD(AX_Y) 		= 0
 
	ACC (AX_Y) 			= 1000
	DEC (AX_Y) 			= 1000
	KDEC(AX_Y) 			= 1000
	JERK (AX_Y) 		= 1000
RET
INPUTSHAPING_ON:
	DISP "Y INPUTSHAPING ON"
	REAL CnvTY(5), CnvAY(5)
	CnvTY(0)	= 0*0.5;      	CnvAY(0)	= 24813/1e5
	CnvTY(1)	= 17*0.5;     	CnvAY(1)	= 8441/1e5
	CnvTY(2)	= 22*0.5;     	CnvAY(2)	= 1639/1e5
	CnvTY(3)	= 27*0.5;    	CnvAY(3)	= 42464/1e5
	CnvTY(4)	= 51*0.5;    	CnvAY(4)	= 22643/1e5  
!-------------------------------------------------------------
InShapeOn AX_Y, CnvTY, CnvAY
WAIT 100
RET

INPUTSHAPING_OFF:
	DISP "Y INPUTSHAPING OFF"
	InShapeOFF AX_Y
RET

RESTORE_TUNING_PARA:
	DISP "Y TUNING PARAMETERS RESTORED"
	SLIKP(AX_Y)				= 1500
	SLIKI(AX_Y)				= 150
	SLPKP(AX_Y)				= 150
	SLPKI(AX_Y)				= 100
	SLVKP(AX_Y)				= 150
	SLVKPIF(AX_Y)			= 1
	SLVKI(AX_Y)				= 100
	SLVSOF(AX_Y)			= 300
	SLAFF(AX_Y)				= 320
	SLVSOFD(AX_Y) 			= 0.9
	SLJFF(AX_Y) 			= 0.3
	MFLAGS(AX_Y).#NOFILT 	= 0

	!Velocity notch filter
	MFLAGS(AX_Y).#NOTCH		= 1
	SLVNATT(AX_Y)			= 3
	SLVNFRQ(AX_Y)			= 512
	SLVNWID(AX_Y)			= 28

	!Velocity BQF 1 
	MFLAGS(AX_Y).#BI_QUAD	= 0
	SLVB0DD(AX_Y)			= 0.4
	SLVB0DF(AX_Y)			= 1495
	SLVB0ND(AX_Y)			= 0.057
	SLVB0NF(AX_Y)			= 1495

	!Velocity BQF 2
	MFLAGS(AX_Y).#BI_QUAD1		= 0
	SLVB1DD(AX_Y)			= 0.0865
	SLVB1DF(AX_Y)			= 516
	SLVB1ND(AX_Y)			= 0.0294
	SLVB1NF(AX_Y)			= 516
	
	!Current limit restoration 
	XCURV(AX_Y)				= 100
	XCURI(AX_Y)				= 50

	!SERVOBOOST 
	DISP "Y SERVOBOOST APLLIED"
	SLSBORD(AX_Y)			= 1
	SLSBBW(AX_Y)			= 30
	SLSBF(AX_Y)				= 900
	!INPOS CRITERION	
	TARGRAD(AX_Y)			= 0.0005
	SETTLE(AX_Y)			= 5
RET
RESTORE_MOTION_PARA:
	SLSBORD(AX_Y) 			= 1
	VEL (AX_Y) 				= 1000
	ACC (AX_Y) 				= 6000
	DEC (AX_Y) 				= 6000
	KDEC(AX_Y) 				= 10000
	JERK (AX_Y) 			= 190000
RET
RESTORE_SAFETY_MASKS:
	FDEF(AX_Y).#RL 			= 1
	FDEF(AX_Y).#LL 			= 1
	FDEF(AX_Y).#SRL 			= 1
	FDEF(AX_Y).#SLL 			= 1					  					  
	FMASK(AX_Y).#RL			= 1
	FMASK(AX_Y).#LL			= 1
	FMASK(AX_Y).#HOT			= 1
	FMASK(AX_Y).#SRL			= 1
	FMASK(AX_Y).#SLL			= 1
	FMASK(AX_Y).#ENCNC		= 0
	FMASK(AX_Y).#ENC2NC		= 0
	FMASK(AX_Y).#DRIVE		= 1
	FMASK(AX_Y).#PE			= 0
	FMASK(AX_Y).#VL			= 1
	FMASK(AX_Y).#STO			= 1
RET
STOP 
