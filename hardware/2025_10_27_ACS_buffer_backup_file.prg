!PNAME=
!PDESC=
! Define Variables

REAL AXIS_ARRAY(7)
REAL TOTAL_AXIS_COUNT
TOTAL_AXIS_COUNT = 6
REAL X
REAL Y = 0

! DEFINE AXIS ARRAY 
AXIS_ARRAY(0) = 0
AXIS_ARRAY(1) = 1
AXIS_ARRAY(2) = 2
AXIS_ARRAY(3) = 3
AXIS_ARRAY(4) = 4
AXIS_ARRAY(5) = 5
AXIS_ARRAY(6) = 6

! function based motion

DISP "ENABLE_ALL"
!GOTO ENABLE_ALL

WAIT 2000 

DISP "HOME_ALL"
GOTO HOME_ALL

WAIT 2000

DISP "PERFORM MOTION"
WAIT 2000




DISP "DISABLE_ALL"
! GOTO DISABLE_ALL
WAIT 2000
STOP


! FUNCTION 1
ENABLE_ALL:
	Y = 0	
	WHILE Y < TOTAL_AXIS_COUNT +1
		DISP "ENABLE", Y
		ENABLE Y 
		Y = Y +1 
		
		
	END 
	STOP

RET


! FUNCTION 2
HOME_ALL:
	START 3,1 ! Z HOME
	WAIT 2000
	START 1, 1 !Y HOME
	WAIT 2000 
	START 0,1 ! X HOME
	STOP
	WAIT 10000
RET



! FUNCTION 20
DISABLE_ALL:
	Y = 0	
	WHILE Y < TOTAL_AXIS_COUNT +1
		DISP "DISABLE", Y
		DISABLE Y 
		Y = Y +1 
		
		
	END 
	STOP
RET
