	ECUNMAPIN(ECGETOFFSET/b("Input",DELTA_IN_UNIT1_SLAVE_ID,1,1))
	ECUNMAPIN(ECGETOFFSET/b("Input",DELTA_IN_UNIT1_SLAVE_ID,1,2))
